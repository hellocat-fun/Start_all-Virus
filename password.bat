@echo off
setlocal enabledelayedexpansion
title 一次性密码生成器

:: ===== 1. 请将您的私钥 Base64 粘贴到下方等号右侧 =====
set "PRIKEY_"

:: ===== 2. 将私钥写入临时文件 =====
set "TEMP_KEY_FILE=%TEMP%\prikey_%RANDOM%.tmp"
echo !PRIKEY_B64! > "!TEMP_KEY_FILE!"

:: ===== 3. 输入解密密钥 =====
set /p "encKey=请输入解密密钥: "
if "%encKey%"=="" (
    echo 密钥不能为空！
    del "!TEMP_KEY_FILE!" >nul 2>&1
    pause
    exit /b
)

:: ===== 4. 调用 PowerShell 解密 =====
powershell -ExecutionPolicy Bypass -Command ^
"$privateKeyXml = [System.Text.Encoding]::UTF8.GetString([Convert]::FromBase64String((Get-Content '%TEMP_KEY_FILE%'))); ^
$rsa = [System.Security.Cryptography.RSA]::Create(); $rsa.FromXmlString($privateKeyXml); ^
$encBytes = [Convert]::FromBase64String('%encKey%'); ^
try { ^
    $key = $rsa.Decrypt($encBytes, [System.Security.Cryptography.RSAEncryptionPadding]::OaepSHA1); ^
    Write-Host '一次性解密密码:' -NoNewline; ^
    Write-Host ([Convert]::ToBase64String($key)) ^
} catch { ^
    Write-Host '错误：密钥无效或私钥不匹配' -ForegroundColor Red; ^
}"

:: ===== 5. 删除临时文件 =====
del "!TEMP_KEY_FILE!" >nul 2>&1
pause